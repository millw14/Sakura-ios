# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# manga files (too large)
/Weekly Viz*/
/public/manga/

# test files
test-*
scripts/test-*

# build artifacts
build.log

# Anchor / Solana build artifacts & keypairs
/target/
Cargo.lock

# Release APK & signing keys
*.apk
*.keystore
*.jks
android/gradle.properties

# reference repos
aniyomi-main/

# private source providers
src/lib/sources/hianime.ts
src/lib/sources/megacloud.ts
android/app/src/main/java/com/millw14/sakura/anime/AnimeScraper.kt
android/app/src/main/java/com/millw14/sakura/anime/WebViewExtractor.kt
